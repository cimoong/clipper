# Copy to .env and fill in. Never commit .env.

# LLM scoring (Google AI Studio: https://aistudio.google.com -> Get API key)
GEMINI_API_KEY=
LLM_PROVIDER=gemini

# Whisper (faster-whisper). Constraint GTX 1060 6GB: max "small" INT8.
WHISPER_MODEL=small
# auto | cuda | cpu
WHISPER_DEVICE=auto

# Clip selection
NUM_CLIPS=8
CLIP_MIN_S=25
CLIP_MAX_S=75

# Working directory for sources/outputs/samples
DATA_DIR=./data
