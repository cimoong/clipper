# Copy to .env and fill in. Never commit .env.

# LLM scoring provider: gemini | anthropic
LLM_PROVIDER=gemini

# Google Gemini (Google AI Studio: https://aistudio.google.com -> Get API key)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (https://console.anthropic.com -> API keys)
ANTHROPIC_API_KEY=
# Model: claude-sonnet-5 (kualitas) | claude-haiku-4-5 (cepat/murah)
# ANTHROPIC_MODEL=claude-sonnet-5

# Whisper (faster-whisper). Constraint GTX 1060 6GB: max "small" INT8.
WHISPER_MODEL=small
# auto | cuda | cpu
WHISPER_DEVICE=auto

# Clip selection
NUM_CLIPS=8
CLIP_MIN_S=25
CLIP_MAX_S=75

# Working directory for sources/outputs/samples
DATA_DIR=./data
